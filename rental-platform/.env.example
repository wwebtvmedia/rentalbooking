# ==========================================
# bestflats.vip - Configuration
# ==========================================

# --- Branding ---
NEXT_PUBLIC_BRAND_NAME=bestflats.vip

# --- Deployment Environment ---
NODE_ENV=production

# --- Backend Settings ---
PORT=4000
# MONGO_URI for internal container network: mongodb://mongo:27017/bestflats
MONGO_URI=mongodb://mongo:27017/bestflats

# Secret for signing JWT. Use a long random string.
AUTH_JWT_SECRET=change-me-to-a-secure-random-value

# CORS: The public URL of your frontend
FRONTEND_ORIGIN=https://www.bestflats.vip

# --- Frontend Settings ---
# This must be the public URL of your API
NEXT_PUBLIC_BACKEND_URL=https://api.bestflats.vip

# --- Email / SMTP Settings ---
# Default for Mailpit container:
SMTP_URL=smtp://mailpit:1025
MAIL_FROM=concierge@bestflats.vip

# --- Stripe Payments (Optional) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd

# --- Business Logic ---
# Default deposit in cents (e.g. 50000 = $500.00)
DEPOSIT_DEFAULT_AMOUNT=0

# --- MCP (Model Context Protocol) ---
ENABLE_MCP_SSE=true
MCP_PORT=8999
