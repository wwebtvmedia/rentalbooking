# Example environment variables for backend
MONGO_URI=mongodb://mongo:27017/rental-platform
LOG_LEVEL=info
PORT=4000
# Secret used to sign JWT bearer tokens. Set to a strong random string in production.
AUTH_JWT_SECRET=change_me_to_a_strong_secret
# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:3000

# Mailer Configuration
# --------------------
# DEVELOPMENT: Use Mailpit (local developer tool that catches emails)
# SMTP_URL=smtp://mailpit:1025
# MAIL_FROM=concierge@bestflats.vip

# PRODUCTION: Use a real SMTP provider (e.g., SendGrid, Mailgun, Gmail)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-real-api-key
# MAIL_FROM=concierge@your-domain.com

# DEBUGGING: Set to true to print Magic Link tokens to the backend console logs.
# Highly recommended on Raspberry Pi if you don't have real SMTP set up yet.
AUTH_LOG_EMAIL_TOKEN=true

# MCP (Model Context Protocol) configuration
ENABLE_MCP_TCP=false
MCP_TCP_PORT=8999

# Stripe configuration (test keys)
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_
# Optional global default deposit amount in cents (if not set per-apartment)
DEPOSIT_DEFAULT_AMOUNT=0

MASTER_ENCRYPTION_KEY=change_me_to_a_strong_master_secret
PLATFORM_ADMIN_KEY=change_me_to_a_strong_admin_key
HOST_INVITE_CODE=change_me_for_host_portal
CONCIERGE_INVITE_CODE=change_me_for_concierge_portal
CONTRACTOR_INVITE_CODE=change_me_for_contractor_portal
